    "/api/v1/instance": {
      "get": {
        "summary": "Query all instances that matches the request parameters.\nEspecially usefull to query all the instances of a source_id.",
        "operationId": "InstanceManager_QueryInstance",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/instanceInstance"
                }
              },
              "title": "Stream result of instanceInstance"
            }
          }
        },
        "parameters": [
          {
            "name": "sourceId",
            "description": "The source (user/team) identifier.",
            "in": "query",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "InstanceManager"
        ]
      },
      "post": {
        "summary": "Create a challenge instance",
        "description": "Instantiates a challenge for a given source ID. The challenge must exist and must not be expired.",
        "operationId": "InstanceManager_CreateInstance",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/instanceInstance"
            }
          },
          "400": {
            "description": "Invalid request arguments.",
            "schema": {},
            "examples": {
              "application/json": {
                "code": 9,
                "message": "Challenge has expired.",
                "details": [
                  {
                    "@type": "type.googleapis.com/google.rpc.ErrorInfo",
                    "reason": "CHALLENGE_EXPIRED",
                    "domain": "github.com/ctfer-io/chall-manager",
                    "metadata": {
                      "id": "1"
                    }
                  },
                  {
                    "@type": "type.googleapis.com/google.rpc.PreconditionFailure",
                    "violations": [
                      {
                        "type": "EXPIRATION",
                        "subject": "github.com/ctfer-io/chall-manager/Challenge",
                        "description": "Challenge has expired so can no longer process instance requests."
                      }
                    ]
                  }
                ]
              }
            }
          },
          "404": {
            "description": "The referenced challenge does not exist.",
            "schema": {},
            "examples": {
              "application/json": {
                "code": 5,
                "message": "Challenge not found.",
                "details": [
                  {
                    "@type": "type.googleapis.com/google.rpc.ErrorInfo",
                    "reason": "CHALLENGE_NOT_FOUND",
                    "domain": "github.com/ctfer-io/chall-manager",
                    "metadata": {
                      "id": "1"
                    }
                  },
                  {
                    "@type": "type.googleapis.com/google.rpc.ResourceInfo",
                    "resourceType": "Challenge",
                    "resourceName": "1",
                    "owner": "",
                    "description": "No challenge with this ID was found."
                  }
                ]
              }
            }
          },
          "409": {
            "description": "An instance already exists for this source ID.",
            "schema": {},
            "examples": {
              "application/json": {
                "code": 6,
                "message": "Instance already exists.",
                "details": [
                  {
                    "@type": "type.googleapis.com/google.rpc.ErrorInfo",
                    "reason": "INSTANCE_ALREADY_EXISTS",
                    "domain": "github.com/ctfer-io/chall-manager",
                    "metadata": {
                      "challenge_id": "1",
                      "source_id": "1"
                    }
                  },
                  {
                    "@type": "type.googleapis.com/google.rpc.ResourceInfo",
                    "resourceType": "Instance",
                    "resourceName": "1/1",
                    "owner": "",
                    "description": "An instance with this ID already exists."
                  }
                ]
              }
            }
          },
          "500": {
            "description": "Internal server error. No internal details are exposed.",
            "schema": {},
            "examples": {
              "application/json": {
                "code": 13,
                "message": "An internal error occurred.",
                "details": [
                  {
                    "@type": "type.googleapis.com/google.rpc.ErrorInfo",
                    "reason": "INTERNAL_ERROR",
                    "domain": "github.com/ctfer-io/chall-manager",
                    "metadata": {}
                  }
                ]
              }
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/instanceCreateInstanceRequest"
            }
          }
        ],
        "tags": [
          "InstanceManager"
        ]
      }
    },
